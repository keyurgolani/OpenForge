# .dockerignore — excludes large/irrelevant files from the Docker build context

# Version control
.git/
.gitignore

# Node
frontend/node_modules/

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
.eggs/

# Environment
.env
.env.*
!.env.example

# Data volumes (should be mounted externally)
data/

# Pre-built static assets (built in Docker stage 1)
static/

# Dev docs
sdlc/
docs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
